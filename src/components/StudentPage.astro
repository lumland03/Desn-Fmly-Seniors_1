---
const { name, image, favorite_emoji, github_permalink, github_profile, codepen_profile, bio, StudentCard} = Astro.props;
---
<!-- <a href="/" class="home"> Home </a> -->
<img src={image} alt={name} />
<h1><span>{favorite_emoji}</span> {name}</h1>
<nav>
  <a href={github_permalink} target="_blank" rel="noopener">Portfolio</a>
  <a href={github_profile} target="_blank" rel="noopener">GitHub</a>
  <a href={codepen_profile} target="_blank" rel="noopener">CodePen</a>
  <a href={StudentCard} target="_blank" rel="noopener"> Back to link</a>
</nav>
<p>{bio}</p>

<style>
  .home{
  background: red;
  padding: 1rem;
  border-radius: 1rem;
}
</style>

<button class="home" onclick="window.location.href='/'">
  Home
</button>